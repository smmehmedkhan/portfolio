{
  "name": "portfolio",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "format": "biome format --write . && stylelint --fix '**/styles/*.{css,scss}'",
    "lint": "biome check . && stylelint '**/styles/*.{css,scss}'",
    "lint:fix": "biome check --fix . && stylelint '**/*.{css,scss}' --fix",
    "check": "biome ci",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:a11y": "pnpm exec playwright test e2e/accessibility.spec.ts",
    "test:perf": "pnpm exec playwright test e2e/performance.spec.ts",
    "test:visual": "pnpm exec playwright test e2e/visual-regression.spec.ts",
    "test:edge": "pnpm test tests/edge-cases/edge-cases.test.tsx -- --run",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "docker:build": "docker build -t portfolio:latest .",
    "docker:run": "docker run -p 3000:3000 portfolio:latest",
    "docker:push": "docker push smmehmedkhan/portfolio:latest",
    "dev": "next dev",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "build": "next build",
    "start": "next start"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css,md}": [
      "biome format --write",
      "biome check --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix"
    ]
  },
  "dependencies": {
    "@arcjet/inspect": "^1.3.1",
    "@arcjet/next": "^1.3.1",
    "@getbrevo/brevo": "^5.0.3",
    "@hookform/resolvers": "^5.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-navigation-menu": "^1.2.14",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.8.0",
    "mongoose": "^9.4.1",
    "motion": "^12.38.0",
    "next": "^16.2.3",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "pino": "^10.3.1",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-github-calendar": "^5.0.5",
    "react-hook-form": "^7.72.1",
    "react-icons": "^5.6.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "vaul": "^1.1.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.11",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/ui": "^4.1.4",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.10.17",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^16.4.0",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.9",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.4"
  },
  "license": "MIT"
}
