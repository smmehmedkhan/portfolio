{
  "name": "portfolio",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.14.0",
  "scripts": {
    "type-check": "tsc --noEmit",
    "lint": "biome check . && stylelint '**/styles/*.{css,scss}'",
    "lint:fix": "biome check --fix . && stylelint '**/*.{css,scss}' --fix",
    "format": "biome format --write . && stylelint --fix '**/styles/*.{css,scss}'",
    "check": "biome ci",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:integration": "vitest run tests/integration",
    "test:api": "vitest run tests/integration/api",
    "test:coverage": "vitest run --coverage",
    "test:a11y": "pnpm exec playwright test tests/e2e/accessibility.spec.ts",
    "test:perf": "pnpm exec playwright test tests/e2e/performance.spec.ts",
    "test:visual": "pnpm exec playwright test tests/e2e/visual-regression.spec.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "docker:build": "docker build -t portfolio:latest .",
    "docker:run": "docker run -p 3000:3000 portfolio:latest",
    "docker:push": "docker push smmehmedkhan/portfolio:latest",
    "dev": "next dev",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:dev:down": "docker-compose -f docker-compose.dev.yml down",
    "build": "next build",
    "start": "node .next/standalone/server.js",
    "clean": "rm -rf .next node_modules test-results playwright-report coverage tests/e2e/snapshots"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,md}": [
      "biome format --write",
      "biome check --write"
    ],
    "*.{css,scss}": [
      "stylelint --fix"
    ]
  },
  "dependencies": {
    "@arcjet/inspect": "^1.9.1",
    "@arcjet/next": "^1.9.1",
    "@getbrevo/brevo": "^6.0.2",
    "@hookform/resolvers": "^5.4.0",
    "@next/third-parties": "^16.2.10",
    "@radix-ui/react-accordion": "^1.2.16",
    "@radix-ui/react-aspect-ratio": "^1.1.11",
    "@radix-ui/react-avatar": "^1.2.2",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-navigation-menu": "^1.2.18",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@vercel/analytics": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "embla-carousel-autoplay": "8.6.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^1.25.0",
    "mongoose": "^9.7.4",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "next-themes": "^0.4.6",
    "ogl": "^1.0.11",
    "pino": "^10.3.1",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-github-calendar": "^5.0.6",
    "react-hook-form": "^7.81.0",
    "react-icons": "^5.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "vaul": "^1.1.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@biomejs/biome": "2.5.4",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/ui": "^4.1.10",
    "autoprefixer": "^10.5.4",
    "baseline-browser-mapping": "^2.10.43",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.0.8",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.19",
    "postcss-html": "^1.8.1",
    "postcss-scss": "^4.0.9",
    "stylelint": "^17.14.0",
    "stylelint-config-standard": "^40.0.0",
    "stylelint-config-tailwindcss": "^1.0.1",
    "stylelint-declaration-strict-value": "^1.11.1",
    "stylelint-order": "^8.1.1",
    "tailwindcss": "^4.3.3",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vitest": "^4.1.10"
  },
  "license": "MIT"
}
